# Flask Configuration
FLASK_DEBUG=false
FLASK_ENV=production

# Database - Xata PostgreSQL Connection
# Lấy từ Xata dashboard
DATABASE_URL=postgresql://xata:YOUR_XATA_API_KEY@YOUR_XATA_WORKSPACE.us-east-1.xata.tech/xata?sslmode=require

# Render Deployment
RENDER=true

# Project B API URL (để gửi dữ liệu trúng tuyển)
# Local: http://localhost:3000
# Production: https://hr.fct.vn
B_API_URL=https://hr.fct.vn
