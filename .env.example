# Flask Configuration
FLASK_DEBUG=false
FLASK_ENV=production

# Database - Xata PostgreSQL Connection
# Lấy từ Xata dashboard
DATABASE_URL=postgresql://xata:YOUR_XATA_API_KEY@YOUR_XATA_WORKSPACE.us-east-1.xata.tech/xata?sslmode=require

# Render Deployment
RENDER=true

# Project B API URL (để gửi dữ liệu trúng tuyển)
# Local: http://localhost:3000
# Production: https://hr.fct.vn
B_API_URL=https://hr.fct.vn

# Cloudflare R2 (để lưu ảnh tài liệu)
# Lấy từ Cloudflare dashboard
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=your_public_url.r2.dev
